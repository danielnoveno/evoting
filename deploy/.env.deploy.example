# VoteChain Deploy Environment
# Copy this to .env.deploy and fill in values
# ⚠️  .env.deploy is git-ignored — never commit it

# ─── VPS Connection (wajib) ──────────────────────────────────────────
VPS_HOST=your_vps_ip_here
VPS_USER=voteinbi
VPS_DIR=/home/voteinbi/app

# ─── Domain ──────────────────────────────────────────────────────────
DOMAIN=votein.biz.id

# ─── Supabase (wajib untuk indexer & backup) ─────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ─── Database Backup (wajib untuk backup-db.sh) ─────────────────────
SUPABASE_HOST=db.your-project.supabase.co
SUPABASE_USER=postgres
SUPABASE_DB=postgres
BACKUP_DIR=/home/voteinbi/backups/database
