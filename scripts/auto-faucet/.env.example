# Coinbase Developer Platform (CDP) credentials
# Dapatkan dari https://portal.cdp.coinbase.com/
CDP_API_KEY_ID=your-api-key-id
CDP_API_KEY_SECRET=your-api-key-secret
CDP_WALLET_SECRET=your-wallet-secret

# Alamat wallet relayer yang akan diisi ETH
RELAYER_ADDRESS=0xYourRelayerWalletAddress

# Target network (default: base-sepolia)
NETWORK=base-sepolia

# Log level (debug, info, warn, error)
LOG_LEVEL=info
