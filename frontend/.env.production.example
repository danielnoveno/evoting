# === PRODUCTION ENV (Netlify) ===
# Deploy: Netlify Dashboard → Site → Environment Variables
# ⚠️  Jangan commit credential ke repo. Set via Netlify UI.

# ─── Blockchain (wajib) ─────────────────────────────────────────────
NEXT_PUBLIC_REGISTRY_ADDRESS=0xYOUR_REGISTRY_ADDRESS
NEXT_PUBLIC_BASE_SEPOLIA_CHAIN_ID=84532
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASESCAN_EXPLORER_URL=https://sepolia.basescan.org
NEXT_PUBLIC_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base-sepolia/YOUR_KEY

# ─── OnChainKit (wajib) ─────────────────────────────────────────────
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_api_key

# ─── Supabase (wajib) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Gemini AI (opsional) ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Notifications ───────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NOTIFICATION_CRON_SECRET=your_cron_secret
COMMIT_REMINDER_WINDOW_MINUTES=30
RESULTS_LOOKBACK_MINUTES=60

# ─── Site URL (WAJIB update ke domain) ──────────────────────────────
NEXT_PUBLIC_SITE_URL=https://votein.biz.id
NEXT_PUBLIC_APP_URL=https://votein.biz.id

# ─── Ponder Indexer (opsional) ──────────────────────────────────────
NEXT_PUBLIC_PONDER_URL=

# ─── Alchemy RPC (fallback) ─────────────────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key

# ─── SMTP Email (WAJIB untuk email aktivasi) ────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=465
SMTP_USER=noreply@votein.biz.id
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@votein.biz.id
EMAIL_FROM_NAME=Sistem Votein
