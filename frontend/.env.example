# === Web3 / OnchainKit ===
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_api_key_here
NEXT_PUBLIC_BASESCAN_EXPLORER_URL=https://sepolia.basescan.org
NEXT_PUBLIC_BASE_SEPOLIA_CHAIN_ID=84532

# === Supabase (browser-safe) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# === Supabase (server-only — never expose to client) ===
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key

# === Resend (email — server-only) ===
# Daftar gratis di https://resend.com, verify domain, lalu isi API key dan dari-email.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=aktivasi@yourdomain.com
RESEND_FROM_NAME=Votein — Portal Admin

# === Site origin (digunakan untuk link aktivasi dan redirect OAuth) ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Gemini (opsional — untuk AI risk summary di dashboard superadmin) ===
GEMINI_API_KEY=your_gemini_api_key_here
