# === Web3 / OnchainKit ===
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_api_key_here
NEXT_PUBLIC_BASESCAN_EXPLORER_URL=https://sepolia.basescan.org
NEXT_PUBLIC_BASE_SEPOLIA_CHAIN_ID=84532

# === Supabase (browser-safe) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# === Supabase (server-only — never expose to client) ===
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key

# === Gmail SMTP (email — server-only) ===
# Gunakan "App Password" dari Google Account untuk SMTP_PASSWORD.
# Host default: smtp.gmail.com, Port: 465 (SSL).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=email-anda@gmail.com
SMTP_PASSWORD=kode-app-password-16-karakter
EMAIL_FROM=email-anda@gmail.com
EMAIL_FROM_NAME=Sistem Votein 

# === Site origin (digunakan untuk link aktivasi dan redirect OAuth) ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Base Sepolia RPC (server-side fallback, opsional) ===
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://base-sepolia-rpc.publicnode.com

# === Reveal Relayer (server-only, untuk pengesahan suara otomatis) ===
# REVEAL_RELAYER_SECRET: password untuk mengakses endpoint /api/relayer/reveal-queued
# REVEAL_RELAYER_PRIVATE_KEY: private key relayer wallet yang punya ETH untuk gas
REVEAL_RELAYER_SECRET=buat_password_acak_yang_kuat
REVEAL_RELAYER_PRIVATE_KEY=0xprivate_key_relayer_yang_punya_eth_base_sepolia

# === Gemini (opsional — untuk AI risk summary di dashboard superadmin) ===
GEMINI_API_KEY=your_gemini_api_key_here
